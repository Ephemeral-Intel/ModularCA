# Copy this file to .env.local for development.
# In Staging/Release builds the admin SPA is served from the same origin as the
# API and this variable is ignored entirely.
#
# Set to the API base URL (no trailing slash) for local development against a
# remote API. There is no longer a hardcoded default — leaving this unset will
# cause API calls to be sent to the current page origin.
#VITE_API_URL=https://localhost:5001
