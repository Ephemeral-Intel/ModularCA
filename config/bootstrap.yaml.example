# Unattended bootstrap configuration
# Only used by --bootstrap CLI mode. The setup wizard collects these values interactively.

CA:
  Subject:
    CN: "ModularCA Root CA"
    O: "ModularCA"
    OU: ["Infrastructure"]
    L: "Austin"
    ST: "Texas"
    C: "US"
  Algorithm: ECDSA
  KeySize: 384
  ValidityYears: 10

SigningProfile:
  Name: "default"
  IsCa: true
  KeyUsages:
    - digitalSignature
    - keyCertSign
    - crlSign
  ExtendedKeyUsages:
    - 1.3.6.1.5.5.7.3.1

Features:
  CRL: true
  OCSP: true
  ACME: true
  EST: true
  SCEP: true
  CMP: true

HttpsApi:
  CN: "ModularCA API"
  SANs:
    - "DNS:localhost"
    - "IP:127.0.0.1"
    - "IP:::1"
  Port: 8443
  ValidityYears: 2
