  Port: 3306
  Database: modularca-app
  Username: modularca_app
  Password: "auto-generated-by-bootstrap"

Audit:
  Host: localhost
  Port: 3306
  Database: modularca-audit
  Username: modularca_audit
  Password: "auto-generated-by-bootstrap"
